# =================================
# E-Commerce Application
# Environment Variables
# =================================

# Database
DATABASE_URL="your-database-url"
DIRECT_DATABASE_URL="your-direct-database-url"

# NextAuth.js
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Public App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email — Resend (https://resend.com)
# Optional, but required for real order confirmations, shipping updates, and welcome emails.
# Without this, emails are logged by the server instead of sent.
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY="your-resend-api-key"
# Use "onboarding@resend.dev" for testing, then switch to your verified domain
EMAIL_FROM="ShopFlow <onboarding@resend.dev>"

# Upstash Redis — required in production for durable rate limiting.
# Without this, production startup fails because per-instance memory is unsafe
# on serverless platforms where cold starts reset rate-limit counters.
# Create a Redis database at https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-upstash-database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token"

# Cloudflare Turnstile (optional)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-turnstile-site-key"
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"

# Social commerce / marketplace channels (optional)
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
META_WEBHOOK_VERIFY_TOKEN="your-meta-webhook-verify-token"
META_API_VERSION="v21.0"
GOOGLE_MERCHANT_CENTER_ID="your-google-merchant-center-id"
GOOGLE_MERCHANT_SERVICE_ACCOUNT_KEY="base64-encoded-service-account-json"
WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-whatsapp-business-account-id"
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-whatsapp-webhook-verify-token"
TIKTOK_APP_KEY="your-tiktok-app-key"
TIKTOK_APP_SECRET="your-tiktok-app-secret"
SNAPCHAT_CLIENT_ID="your-snapchat-client-id"
SNAPCHAT_CLIENT_SECRET="your-snapchat-client-secret"

# Tap Payments (optional)
TAP_SECRET_KEY="your-tap-secret-key"
TAP_PUBLIC_KEY="your-tap-public-key"

# Rate limits (optional; format maxRequests/windowSeconds)
RATE_LIMIT_AUTH="10/60"
RATE_LIMIT_CHECKOUT="20/60"
RATE_LIMIT_FORM="10/60"
RATE_LIMIT_SEARCH="60/60"
RATE_LIMIT_COUPON="20/60"
RATE_LIMIT_PAYMENT="20/60"
RATE_LIMIT_PASSWORD_RESET="5/900"
RATE_LIMIT_WEBHOOK="120/60"
RATE_LIMIT_REFUND="10/60"
RATE_LIMIT_ZATCA_RETRY="10/60"
RATE_LIMIT_ZATCA_ONBOARD="5/300"
RATE_LIMIT_DAILY_ORDER="1000/86400"
RATE_LIMIT_DAILY_REFUND="100/86400"

# Invoice monitor (optional)
MONITOR_SPIKE_THRESHOLD_IP="10"
MONITOR_SPIKE_THRESHOLD_GLOBAL="50"
MONITOR_RAPID_FIRE_MS="1000"
MONITOR_RAPID_FIRE_COUNT="5"
MONITOR_ALERT_COOLDOWN_MS="300000"
MONITOR_ADMIN_EMAIL=""

# Node Environment
NODE_ENV="development"
